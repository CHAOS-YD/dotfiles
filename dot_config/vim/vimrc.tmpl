" ========== Unix Vim Configuration ==========
" This file is managed by chezmoi. Rendered as ~/.vimrc (or ~/.config/vim/vimrc).
" It is intended for Unix-like systems only. If loaded on Windows, it warns and exits.

" ----- Platform guard: only proceed on Unix-like systems -----
if has('win32') || has('win64')
    echohl WarningMsg
    echo "Warning: This Vim configuration is intended for Unix-like systems."
    echo "It appears you are running on Windows. Please use the appropriate config."
    echohl None
    finish
endif

" ----- Include common core (basic settings, directories, shell, clipboard) -----
{{ template "editors/common/core.vim" . }}

" ----- Include Vim core (auto-install vim-plug) -----
{{ template "editors/vim/core.vim" . }}

" ----- Plugin manager and modules -----
if exists('s:editor_data_dir')
  let s:plugged_dir = s:editor_data_dir . '/plugged'
  call plug#begin(s:plugged_dir)

  " Source plugin modules from the directory defined in common/core.vim
  if exists('g:vim_plugin_modules_dir')
    execute 'source ' . g:vim_plugin_modules_dir . '/core.vim'
    execute 'source ' . g:vim_plugin_modules_dir . '/lsp.vim'
    execute 'source ' . g:vim_plugin_modules_dir . '/ui.vim'
    execute 'source ' . g:vim_plugin_modules_dir . '/git.vim'
    execute 'source ' . g:vim_plugin_modules_dir . '/tools.vim'
  else
    echo "Warning: g:vim_plugin_modules_dir not defined, cannot load plugin modules."
  endif

  call plug#end()
else
  echo "s:editor_data_dir not defined, cannot load plugins."
endif

" ----- Key mappings -----
{{ template "editors/common/mappings.vim" . }}
{{ template "editors/vim/mappings.vim" . }}
