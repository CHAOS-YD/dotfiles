# Core rule: let Git automatically detect text files and convert based on platform.
* text=auto

# If you have any files that MUST be LF even in working directory (e.g., shell scripts for WSL),
# keep them with explicit eol=lf. Otherwise, remove all eol=lf lines.
# For your current needs (all CRLF in working tree), you can delete all eol=lf rules below.

# Example of keeping LF for specific files (uncomment if needed):
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files
*.png     binary
*.jpg     binary
*.gz      binary
*.zip     binary
*.ico     binary
